rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      // Ranking é leitura pública para autenticados (xpTotal/streakDays/xpHistory
      // vivem no documento/subcoleções do usuário); escrita apenas pelo próprio dono.
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      match /{document=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /trails/{trailId} {
      allow read: if request.auth != null;
      allow write: if false;
      match /{document=**} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /activities/{activityId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /achievements/{achievementId} {
      // Catálogo lido pelo front; escrita só via seeder (admin SDK ignora as rules).
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /leagues/{leagueId} {
      allow read: if request.auth != null;
      allow write: if false;
      match /members/{memberId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
